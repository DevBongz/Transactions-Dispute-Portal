{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=disputeportal;Username=dp_user;Password=dp_pass"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ClientId": "dispute-portal-api",
    "Topics": {
      "DisputeSubmitted": "dispute.submitted",
      "DisputeClassified": "dispute.classified",
      "DisputeResolved": "dispute.resolved"
    },
    "ProducerAcks": "All",
    "MessageTimeoutMs": 5000
  },
  "Anthropic": {
    "ApiKey": "",
    "BaseUrl": "https://api.anthropic.com",
    "AnthropicVersion": "2023-06-01",
    "ExtractionModel": "claude-haiku-4-5-20251001",
    "ExtractionMaxTokens": 1024,
    "ExtractionTimeoutSeconds": 5,
    "ClassificationModel": "claude-haiku-4-5-20251001",
    "ClassificationMaxTokens": 512,
    "ClassificationTimeoutSeconds": 5,
    "SummaryModel": "claude-sonnet-5",
    "SummaryMaxTokens": 512,
    "SummaryTimeoutSeconds": 15,
    "MaxExtractionInputChars": 4000
  },
  "Jwt": {
    "Issuer": "dispute-portal",
    "Audience": "dispute-portal-clients",
    "Secret": "",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  }
}
